{
    "name": "proweb/yii2-cookies-agreement",
    "description": "Sticky footer panel widget, which lets your visitors to accept user policy agreement.",
    "type": "yii2-extension",
    "keywords": [
        "yii2",
        "extension",
        "cookies",
        "policy",
        "agreement"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "AndrewDanilov",
            "email": "andrewdanilov@gmail.com"
        },
        {
            "name": "Sergey Mochalov",
            "homepage": "https://sg43.ru"
        }
    ],
    "require": {
        "php": ">=8.0.0",
        "yiisoft/yii2": "^2.0.49"
    },
    "autoload": {
        "psr-4": {
            "proweb\\CookiesAgreement\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "support": {
        "issues": "https://github.com/yii2-ext/yii2-cookies-agreement/issues",
        "source": "https://github.com/yii2-ext/yii2-cookies-agreement"
    }
}